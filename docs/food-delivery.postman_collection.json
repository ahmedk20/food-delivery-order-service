{
  "info": {
    "name": "Food Delivery Core Service",
    "_postman_id": "food-delivery-core-service",
    "description": "API collection for the Food Delivery Core Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the service and database are healthy."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"ok\": true\n}"
            },
            {
              "name": "Database Error",
              "status": "Internal Server Error",
              "code": 500,
              "body": "{\n  \"message\": \"database error\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('accessToken', json.accessToken);",
                  "  pm.environment.set('refreshToken', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"phone\": \"0512345678\",\n  \"name\": \"John Doe\",\n  \"password\": \"Password1!\",\n  \"role\": \"customer\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user. Roles: customer | delivery_agent | restaurant_user | system_admin.\n\nPassword must be at least 8 chars with uppercase, lowercase, number, and symbol.\n\nSets `access_token` and `refresh_token` cookies on success."
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"accessToken\": \"<jwt>\",\n  \"refreshToken\": \"<jwt>\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('accessToken', json.accessToken);",
                  "  pm.environment.set('refreshToken', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password1!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email and password. Sets `access_token` and `refresh_token` cookies on success."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"accessToken\": \"<jwt>\",\n  \"refreshToken\": \"<jwt>\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Refresh the access token using the `refresh_token` cookie. Rotates the refresh token on success."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Token refreshed\"\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Invalid or expired refresh token\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.unset('accessToken');",
                  "  pm.environment.unset('refreshToken');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout the current user. Revokes the refresh token and clears `access_token` and `refresh_token` cookies."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Logged out successfully\"\n}"
            }
          ]
        },
        {
          "name": "Forget Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forget-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forget-password"]
            },
            "description": "Request a password reset OTP sent to the provided email."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Email Sent with OTP\"\n}"
            }
          ]
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword1!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Reset the password using the 6-digit OTP received by email.\n\nnewPassword must be at least 8 chars with uppercase, lowercase, number, and symbol."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Password reset successfully, please login again\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Name\",\n  \"phone\": \"01000000001\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["user", "me"]
            },
            "description": "Update the authenticated user's profile. Both fields are optional."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Profile updated\",\n  \"user\": {\n    \"id\": 1,\n    \"email\": \"user@email.com\",\n    \"phone\": \"01000000001\",\n    \"name\": \"New Name\",\n    \"systemRole\": \"customer\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "Or use the access_token cookie set by login/register"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["user", "me"]
            },
            "description": "Get the currently authenticated user's profile. Requires a valid access token (cookie or Authorization header)."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"email\": \"john@example.com\",\n  \"name\": \"John Doe\",\n  \"phone\": \"0512345678\",\n  \"role\": \"customer\"\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Unauthorized\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Customer / Addresses",
      "item": [
        {
          "name": "Get Addresses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/customer/addresses",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "addresses"]
            },
            "description": "Get all addresses for the authenticated customer."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"label\": \"Home\",\n      \"country\": \"EG\",\n      \"city\": \"Cairo\",\n      \"street\": \"Street 1\",\n      \"building\": \"12\",\n      \"apartmentNumber\": \"3A\",\n      \"type\": \"home\",\n      \"lat\": 30.1,\n      \"lng\": 31.2,\n      \"isDefault\": true\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Home\",\n  \"country\": \"EG\",\n  \"city\": \"Cairo\",\n  \"street\": \"Street 1\",\n  \"building\": \"12\",\n  \"apartmentNumber\": \"3A\",\n  \"type\": \"home\",\n  \"lat\": 30.1,\n  \"lng\": 31.2,\n  \"isDefault\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/customer/addresses",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "addresses"]
            },
            "description": "Add a new address. type: home | office | public_place. If isDefault is true, all other addresses are unset as default."
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Address added\",\n  \"address\": {\n    \"id\": 1,\n    \"label\": \"Home\",\n    \"country\": \"EG\",\n    \"city\": \"Cairo\",\n    \"street\": \"Street 1\",\n    \"building\": \"12\",\n    \"apartmentNumber\": \"3A\",\n    \"type\": \"home\",\n    \"lat\": 30.1,\n    \"lng\": 31.2,\n    \"isDefault\": false\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Work\",\n  \"country\": \"EG\",\n  \"city\": \"Cairo\",\n  \"street\": \"New Street\",\n  \"building\": \"5\",\n  \"apartmentNumber\": \"2B\",\n  \"type\": \"office\",\n  \"lat\": 30.2,\n  \"lng\": 31.3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/customer/addresses/:addressId",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "addresses", ":addressId"],
              "variable": [
                {
                  "key": "addressId",
                  "value": "1"
                }
              ]
            },
            "description": "Update an existing address. All fields are optional. Only the authenticated user's own addresses can be updated."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Address updated\",\n  \"address\": {\n    \"id\": 1,\n    \"label\": \"Work\",\n    \"country\": \"EG\",\n    \"city\": \"Cairo\",\n    \"street\": \"New Street\",\n    \"building\": \"5\",\n    \"apartmentNumber\": \"2B\",\n    \"type\": \"office\",\n    \"lat\": 30.2,\n    \"lng\": 31.3,\n    \"isDefault\": false\n  }\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"message\": \"Address not found\"\n}"
            }
          ]
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/customer/addresses/:addressId",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "addresses", ":addressId"],
              "variable": [
                {
                  "key": "addressId",
                  "value": "1"
                }
              ]
            },
            "description": "Delete an address. Only the authenticated user's own addresses can be deleted."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Address deleted\"\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"message\": \"Address not found\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
