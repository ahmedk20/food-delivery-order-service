{
  "name": "order-service",
  "version": "1.0.0",
  "description": "QuickBite — Order & Payment microservice",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "migrate:latest": "knex --knexfile dist/lib/knex/knexfile.js migrate:latest",
    "migrate:up": "knex --knexfile dist/lib/knex/knexfile.js migrate:up",
    "migrate:down": "knex --knexfile dist/lib/knex/knexfile.js migrate:down"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "axios": "^1.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.1.3",
    "knex": "^3.1.0",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "private": true
}
