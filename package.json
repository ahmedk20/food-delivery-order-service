{
  "name": "order-service",
  "version": "1.0.0",
  "description": "QuickBite — Order & Payment microservice",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "migrate:latest": "cross-env APP_STAGE=dev tsx ./node_modules/knex/bin/cli.js --knexfile src/lib/knex/knexfile.ts migrate:latest",
    "migrate:rollback": "cross-env APP_STAGE=dev tsx ./node_modules/knex/bin/cli.js --knexfile src/lib/knex/knexfile.ts migrate:rollback",
    "migrate:down": "cross-env APP_STAGE=dev tsx ./node_modules/knex/bin/cli.js --knexfile src/lib/knex/knexfile.ts migrate:down",
    "migrate:all": "tsx scripts/migrate-all.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.1.3",
    "knex": "^3.1.0",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "tsyringe": "^4.10.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "private": true
}
